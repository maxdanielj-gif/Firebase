rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: items
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 500 chars) - The content of the item
    //   - userId: string (required, immutable) - The UID of the user who created the item
    //   - createdAt: number (required, immutable) - Timestamp of creation
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidItem(data) {
      return hasOnlyAllowedFields(['text', 'userId', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.userId is string &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /items/{itemId} {
      // Users can only read their own items
      allow read: if isDocOwner();
      
      // Users can create items, but they must be the owner and data must be valid
      allow create: if isAuthenticated() && 
                       isValidItem(request.resource.data) && 
                       request.resource.data.userId == request.auth.uid;
                       
      // Users can update their own items, but userId and createdAt must be immutable
      allow update: if isDocOwner() && 
                       isValidItem(request.resource.data) && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
                       
      // Users can delete their own items
      allow delete: if isDocOwner();
    }
    
    // Connection test document
    match /test/connection {
      allow read: if true; // Allow public read for connection testing only
      allow write: if false;
    }
  }
}
